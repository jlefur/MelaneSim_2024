!!!263938.java!!!	actionDisperse() : void
		if ((nextMove_Umeter.x == 0) && (nextMove_Umeter.y == 0)) this.setNewRandomMove();
		for (int i = 0; i < REPEAT_DISPERSAL; i++)
			if (!this.hasEnteredDomain) this.actionMove();
